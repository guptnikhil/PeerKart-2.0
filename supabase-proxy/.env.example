# ─────────────────────────────────────────────────────────────
#  Supabase Proxy – Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Full URL of your Supabase project (no trailing slash)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# The public URL where THIS proxy is reachable (no trailing slash)
# After deploying to Cloud Run, paste the Service URL here and redeploy.
PROXY_URL=https://YOUR_CLOUD_RUN_SERVICE_URL

# Your Supabase anon (public) key
SUPABASE_ANON_KEY=your-supabase-anon-key

# (Optional) Service-role key – only needed for admin operations
# SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Comma-separated list of allowed frontend origins (or * for dev/testing)
# Example: https://www.peerkart.com,https://peerkart.com
FRONTEND_ORIGIN=*

# Port the proxy listens on locally (Cloud Run sets this automatically)
PORT=3000

# ─────────────────────────────────────────────────────────────
#  Google Cloud Run Deployment  (used by deploy.sh only)
# ─────────────────────────────────────────────────────────────

# Your GCP project ID (visible in Cloud Console)
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run region (e.g. us-central1, asia-south1, europe-west1)
GCP_REGION=us-central1

# Cloud Run service name (can be anything, default: supabase-proxy)
SERVICE_NAME=supabase-proxy
